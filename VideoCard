import { Play } from "lucide-react";
import { useState } from "react";

interface VideoCardProps {
  id: string;
  title: string;
  thumbnail: string;
  duration?: string;
  rating?: string;
  genre?: string;
  onPlay?: () => void;
}

/**
 * VideoCard Component
 * Displays a video thumbnail with hover effects, play button, and metadata.
 * Cinematic Dark Elegance design: Smooth scale-up on hover, gradient overlay, centered play icon.
 */
export default function VideoCard({
  id,
  title,
  thumbnail,
  duration,
  rating,
  genre,
  onPlay,
}: VideoCardProps) {
  const [isHovering, setIsHovering] = useState(false);

  return (
    <div
      className="video-card"
      onMouseEnter={() => setIsHovering(true)}
      onMouseLeave={() => setIsHovering(false)}
      onClick={onPlay}
    >
      {/* Thumbnail Image */}
      <img
        src={thumbnail}
        alt={title}
        className="w-full h-full object-cover"
      />

      {/* Gradient Overlay on Hover */}
      <div className="video-card-overlay">
        <button className="play-button" aria-label="Play video">
          <Play className="w-8 h-8 text-white fill-white" />
        </button>
      </div>

      {/* Metadata Overlay (Always visible) */}
      <div className="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent p-4">
        <h3 className="text-white font-bold text-sm line-clamp-2 mb-2">
          {title}
        </h3>

        <div className="flex items-center justify-between text-xs text-gray-300 gap-2">
          {rating && (
            <div className="flex items-center gap-1">
              <span className="text-primary">★</span>
              <span>{rating}</span>
            </div>
          )}
          {genre && <span className="text-muted-foreground">{genre}</span>}
          {duration && <span className="text-muted-foreground">{duration}</span>}
        </div>
      </div>
    </div>
  );
}
